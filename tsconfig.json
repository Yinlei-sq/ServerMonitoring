{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "types": ["node", "vscode"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts", "esbuild.mjs"],
  "exclude": ["dist", "node_modules"]
}
